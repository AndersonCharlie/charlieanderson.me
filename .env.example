# Booking backend — copy to .env for local dev; set the same vars in the
# Vercel project for production. NEVER commit .env.

# From ~/scripts: python3 ~/scripts/calendar_auth.py  (prints all three)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# The Zoom link every confirmation email + calendar event carries.
BOOKING_ZOOM_URL=

# Everything below has these values as defaults — set only to override.
#BOOKING_CALENDAR_ID=primary
#BOOKING_TZ=America/New_York
#BOOKING_HOURS=Mon-Fri 09:00-17:00
#BOOKING_DURATION_MIN=30
#BOOKING_BUFFER_MIN=10
#BOOKING_MIN_NOTICE_H=12
#BOOKING_MAX_DAYS=21
#BOOKING_MEETING_TYPE=30-min strategy call
#BOOKING_CONFIRM_FROM=charlie@charlieanderson.me
#BOOKING_FROM_NAME=Charlie Anderson
#BOOKING_SEND_EMAIL=true

# Local testing without Google credentials (in-memory calendar):
#BOOKING_MOCK=1
#BOOKING_MOCK_BUSY=2026-07-06T14:00:00Z/2026-07-06T15:00:00Z
